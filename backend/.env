# ─────────────────────────────────────────────
#  NestJS Backend – Environment Variables
# ─────────────────────────────────────────────

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/pi4eme

# JWT secret (change this to a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend URL (used for the reset-password link in emails)
FRONTEND_URL=http://localhost:4200

# ─────────────────────────────────────────────
#  SMTP / Email configuration
#  Fill in the details for your email provider.
#
#  → Gmail example (use an App Password, NOT your real password):
#      SMTP_HOST=smtp.gmail.com
#      SMTP_PORT=587
#      SMTP_USER=your-address@gmail.com
#      SMTP_PASS=xxxx xxxx xxxx xxxx   ← 16-char App Password
#      MAIL_FROM=your-address@gmail.com
#
#  → Outlook / Hotmail example:
#      SMTP_HOST=smtp-mail.outlook.com
#      SMTP_PORT=587
#      SMTP_USER=your-address@outlook.com
#      SMTP_PASS=your-password
#      MAIL_FROM=your-address@outlook.com
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ttttfarah@gmail.com
SMTP_PASS=ozgpbrxwugzhcwgi
MAIL_FROM=ttttfarah@gmail.com
